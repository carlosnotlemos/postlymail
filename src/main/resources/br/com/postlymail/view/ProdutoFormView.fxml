<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="15" styleClass="card" 
      prefWidth="400"
      stylesheets="@../css/style.css">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="lblTitulo" text="Novo Produto" styleClass="card-title" style="-fx-font-size: 20px;" />

    <VBox spacing="5">
        <Label text="Nome do Produto" style="-fx-text-fill: #bac2de;" />
        <TextField fx:id="txtNome" promptText="Ex: Assinatura Premium" />
    </VBox>

    <VBox spacing="5">
        <Label text="Categoria" style="-fx-text-fill: #bac2de;" />
        <TextField fx:id="txtCategoria" promptText="Ex: Serviços" />
    </VBox>

    <HBox spacing="15">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Preço (R$)" style="-fx-text-fill: #bac2de;" />
            <TextField fx:id="txtPreco" promptText="0.00" />
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Estoque" style="-fx-text-fill: #bac2de;" />
            <TextField fx:id="txtEstoque" promptText="0" />
        </VBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#handleCancelar" style="-fx-background-color: transparent; -fx-text-fill: #f38ba8; -fx-cursor: hand;" />
        <Button text="Salvar Produto" onAction="#handleSalvar" styleClass="button-primary" />
    </HBox>

</VBox>
